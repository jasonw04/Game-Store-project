<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Game Store (Assignment 1)</title>

  <!-- style sheet-->
  <link rel="stylesheet" href="styles.css" />
  
  <script src="script.js" defer></script>
</head>

<body>
  <!-- Common page layout tags (lecture: header/nav/section/footer) -->
  <header id="site_header">
    <h1 id="site_title">Game Store</h1>

    <!-- NAV built from an unordered list (lecture Topic 3 menu) -->
    <nav id="main_nav">
      <ul id="nav_list">
        <li><a href="#" id="nav_home">Home</a></li>
        <li><a href="#" id="nav_games">Games</a></li>
        <li><a href="#" id="nav_about">About</a></li>
        <li>
          <a href="#" id="nav_wishlist">
            Wishlist (<span id="wishlist_count">0</span>)
          </a>
        </li>
        <li>
          <a href="#" id="nav_cart">
            Cart (<span id="cart_count">0</span>)
          </a>
        </li>
        <li><a href="#" id="nav_checkout">Checkout</a></li>
      </ul>
    </nav>
  </header>

  <!-- MAIN CONTENT AREA -->
  <main id="main_content">

    <!-- HOME "PAGE" (single-file approach: hide/show sections with JS) -->
    <section id="page_home" class="page">
      <h2>Home</h2>

      <!-- Basic "carousel" structure (no library; JS can switch slides) -->
      <section id="hero_carousel">
        <h3>Featured</h3>

        <div id="carousel_viewport">
          <!-- JS can update this area (lecture: DOM manipulation via id) -->
          <div id="carousel_slide">
            <h4 id="carousel_game_title">Featured Game Title</h4>
            <p id="carousel_game_desc">Featured game description goes here.</p>

            <!-- Image placeholder (lecture: img + alt) -->
            <img
              id="carousel_game_img"
              src="images/placeholder.jpg"
              alt="Featured game image"
            />

            <p>
              <button type="button" id="btn_carousel_view_details">View Details</button>
              <button type="button" id="btn_carousel_add_cart">Add to Cart</button>
              <button type="button" id="btn_carousel_add_wishlist">Add to Wishlist</button>
            </p>
          </div>
        </div>

        <p>
          <button type="button" id="btn_carousel_prev">Previous</button>
          <button type="button" id="btn_carousel_next">Next</button>
        </p>
      </section>

      <!-- Recommended list (can be hardcoded or rendered by JS) -->
      <section id="recommended_section">
        <h3>Recommended</h3>

        <!-- Keep it basic: container that JS can fill with game cards -->
        <div id="recommended_list">
          <!-- Example static item (JS can replace) -->
          <div class="game_card">
            <h4>Recommended Game</h4>
            <p>Short description.</p>
            <button type="button" class="btn_view_details">View Details</button>
          </div>
        </div>
      </section>
    </section>

    <!-- GAMES LISTING "PAGE" -->
    <section id="page_games" class="page hidden">
      <h2>Games</h2>

      <!-- Filtering / Sorting / Search controls -->
      <section id="games_controls">
        <h3>Browse</h3>

        <form id="filter_form" action="#" method="get">
          <p>
            <label for="search_name">Search by name:</label><br />
            <input type="text" id="search_name" name="search_name" />
            <button type="button" id="btn_search">Search</button>
          </p>

          <p>
            <label for="filter_category">Category:</label><br />
            <select id="filter_category" name="filter_category">
              <option value="">All</option>
              <option value="action">Action</option>
              <option value="rpg">RPG</option>
              <option value="sports">Sports</option>
              <option value="strategy">Strategy</option>
            </select>
          </p>

          <p>
            <label for="filter_platform">Platform:</label><br />
            <select id="filter_platform" name="filter_platform">
              <option value="">All</option>
              <option value="pc">PC</option>
              <option value="ps5">PS5</option>
              <option value="xbox">Xbox</option>
              <option value="switch">Switch</option>
            </select>
          </p>

          <p>
            <label for="filter_price">Price Range:</label><br />
            <select id="filter_price" name="filter_price">
              <option value="">All</option>
              <option value="0-20">$0–$20</option>
              <option value="20-40">$20–$40</option>
              <option value="40-60">$40–$60</option>
              <option value="60+">$60+</option>
            </select>
          </p>

          <p>
            <label for="sort_by">Sort By:</label><br />
            <select id="sort_by" name="sort_by">
              <option value="name_asc">Name (A–Z)</option>
              <option value="name_desc">Name (Z–A)</option>
              <option value="price_asc">Price (Low–High)</option>
              <option value="price_desc">Price (High–Low)</option>
              <option value="rating_desc">Rating (High–Low)</option>
            </select>
            <button type="button" id="btn_apply_sort">Apply</button>
          </p>

          <p>
            <!-- Grid/List toggle must update immediately (JS) -->
            <button type="button" id="btn_view_grid">Grid View</button>
            <button type="button" id="btn_view_list">List View</button>
          </p>

          <p>
            <button type="button" id="btn_clear_filters">Clear</button>
          </p>
        </form>
      </section>

      <!-- Games output -->
      <section id="games_output">
        <h3>Results</h3>

        <!-- JS will render games here -->
        <div id="games_list" class="grid_view">
          <!-- Example placeholder item -->
          <div class="game_card">
            <h4>Game Title</h4>
            <p>Category: Action</p>
            <p>Platform: PC</p>
            <p>Price: $49.99</p>
            <p>Rating: 4.5</p>
            <button type="button" class="btn_view_details">View Details</button>
            <button type="button" class="btn_add_cart">Add to Cart</button>
            <button type="button" class="btn_add_wishlist">Add to Wishlist</button>
          </div>
        </div>
      </section>
    </section>

    <!-- GAME DETAIL "PAGE" -->
    <section id="page_detail" class="page hidden">
      <h2>Game Details</h2>

      <section id="detail_main">
        <h3 id="detail_title">Game Title</h3>
        <p id="detail_description">Full description goes here.</p>

        <img
          id="detail_main_img"
          src="images/placeholder.jpg"
          alt="Main game image"
        />

        <p>
          <button type="button" id="btn_detail_add_cart">Add to Cart</button>
          <button type="button" id="btn_detail_add_wishlist">Add to Wishlist</button>
        </p>
      </section>

      <!-- Thumbnails (>=4) -->
      <section id="detail_thumbnails">
        <h3>Thumbnails</h3>
        <ul id="thumbnail_list">
          <li><img class="thumb_img" src="images/placeholder.jpg" alt="Thumbnail 1" /></li>
          <li><img class="thumb_img" src="images/placeholder.jpg" alt="Thumbnail 2" /></li>
          <li><img class="thumb_img" src="images/placeholder.jpg" alt="Thumbnail 3" /></li>
          <li><img class="thumb_img" src="images/placeholder.jpg" alt="Thumbnail 4" /></li>
        </ul>
      </section>

      <!-- Screenshots (>=4) -->
      <section id="detail_screenshots">
        <h3>Screenshots</h3>
        <ul id="screenshot_list">
          <li><img class="shot_img" src="images/placeholder.jpg" alt="Screenshot 1" /></li>
          <li><img class="shot_img" src="images/placeholder.jpg" alt="Screenshot 2" /></li>
          <li><img class="shot_img" src="images/placeholder.jpg" alt="Screenshot 3" /></li>
          <li><img class="shot_img" src="images/placeholder.jpg" alt="Screenshot 4" /></li>
        </ul>
      </section>

      <!-- Specs -->
      <section id="detail_specs">
        <h3>Specifications</h3>
        <ul>
          <li><strong>Type:</strong> <span id="spec_type">Action</span></li>
          <li><strong>Platform:</strong> <span id="spec_platform">PC</span></li>
          <li><strong>Release Date:</strong> <span id="spec_release">01/01/2026</span></li>
          <li><strong>Rating:</strong> <span id="spec_rating">4.5</span></li>
        </ul>
      </section>

      <!-- Reviews -->
      <section id="detail_reviews">
        <h3>Reviews</h3>
        <ul id="review_list">
          <li>“Great gameplay!” — User A</li>
          <li>“Worth it.” — User B</li>
          <li>“Looks amazing.” — User C</li>
        </ul>
      </section>

      <p>
        <button type="button" id="btn_back_to_games">Back to Games</button>
      </p>
    </section>

    <!-- WISHLIST "PAGE" -->
    <section id="page_wishlist" class="page hidden">
      <h2>Wishlist</h2>

      <p>Your saved items:</p>

      <!-- Basic table structure (lecture: tables) -->
      <table id="wishlist_table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Price</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="wishlist_rows">
          <!-- JS populates rows -->
          <tr>
            <td>Example Game</td>
            <td>$49.99</td>
            <td>
              <button type="button" class="btn_move_to_cart">Move to Cart</button>
              <button type="button" class="btn_remove_wishlist">Remove</button>
            </td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- CART "PAGE" -->
    <section id="page_cart" class="page hidden">
      <h2>Cart</h2>

      <table id="cart_table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Line Total</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="cart_rows">
          <!-- JS populates rows -->
          <tr>
            <td>Example Game</td>
            <td>$49.99</td>
            <td>
              <button type="button" class="btn_qty_minus">-</button>
              <span class="qty_value">1</span>
              <button type="button" class="btn_qty_plus">+</button>
            </td>
            <td>$49.99</td>
            <td>
              <button type="button" class="btn_remove_cart">Remove</button>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- Totals -->
      <section id="cart_totals">
        <h3>Totals</h3>
        <p>Subtotal: $<span id="subtotal_value">0.00</span></p>
        <p>Tax (13%): $<span id="tax_value">0.00</span></p>
        <p><strong>Total: $<span id="total_value">0.00</span></strong></p>

        <p>
          <button type="button" id="btn_cart_to_checkout">Go to Checkout</button>
        </p>
      </section>
    </section>

    <!-- CHECKOUT "PAGE" -->
    <section id="page_checkout" class="page hidden">
      <h2>Checkout</h2>

      <!-- Form structure (lecture: forms, labels, inputs, submit) -->
      <form id="checkout_form" action="#" method="post">
        <fieldset>
          <legend>Payment Information</legend>

          <p>
            <label for="pay_name">Name on Card:</label><br />
            <input type="text" id="pay_name" name="pay_name" />
            <span class="error_text" id="err_pay_name"></span>
          </p>

          <p>
            <label for="pay_card">Card Number (16 digits):</label><br />
            <input type="text" id="pay_card" name="pay_card" />
            <span class="error_text" id="err_pay_card"></span>
          </p>

          <p>
            <label for="pay_exp">Expiry (MM/YY):</label><br />
            <input type="text" id="pay_exp" name="pay_exp" />
            <span class="error_text" id="err_pay_exp"></span>
          </p>

          <p>
            <label for="pay_cvv">CVV (3 or 4 digits):</label><br />
            <input type="text" id="pay_cvv" name="pay_cvv" />
            <span class="error_text" id="err_pay_cvv"></span>
          </p>

          <p>
            <label for="pay_email">Email:</label><br />
            <input type="text" id="pay_email" name="pay_email" />
            <span class="error_text" id="err_pay_email"></span>
          </p>

          <p>
            <button type="button" id="btn_place_order">Place Order</button>
          </p>

          <!-- Simulated processing message (spinner can be CSS) -->
          <p id="processing_area" class="hidden">
            Processing your payment...
          </p>
        </fieldset>
      </form>
    </section>

    <!-- RECEIPT "PAGE" -->
    <section id="page_receipt" class="page hidden">
      <h2>Receipt</h2>

      <p><strong>Order Number:</strong> <span id="receipt_order_number">ORD-YYYYMMDD-0000</span></p>
      <p><strong>Order Date:</strong> <span id="receipt_order_date">DD/MM/YYYY</span></p>
      <p><strong>Email:</strong> <span id="receipt_email">example@email.com</span></p>

      <h3>Items</h3>
      <table id="receipt_table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Line Total</th>
          </tr>
        </thead>
        <tbody id="receipt_rows">
          <!-- JS fills receipt lines -->
        </tbody>
      </table>

      <h3>Totals</h3>
      <p>Subtotal: $<span id="receipt_subtotal">0.00</span></p>
      <p>Tax (13%): $<span id="receipt_tax">0.00</span></p>
      <p><strong>Total: $<span id="receipt_total">0.00</span></strong></p>

      <p>
        <button type="button" id="btn_continue_shopping">Continue Shopping</button>
        <button type="button" id="btn_print_receipt">Print / Save as PDF</button>
      </p>
    </section>

    <!-- ABOUT "PAGE" -->
    <section id="page_about" class="page hidden">
      <h2>About</h2>

      <p id="about_text">
        Welcome to Game Store. We sell great games across multiple platforms.
      </p>

      <h3>Contact Us</h3>
      <form id="contact_form" action="#" method="post">
        <fieldset>
          <legend>Send a Message</legend>

          <p>
            <label for="contact_email">Email:</label><br />
            <input type="text" id="contact_email" name="contact_email" />
            <span class="error_text" id="err_contact_email"></span>
          </p>

          <p>
            <label for="contact_message">Message:</label><br />
            <input type="text" id="contact_message" name="contact_message" />
            <span class="error_text" id="err_contact_message"></span>
          </p>

          <p>
            <button type="button" id="btn_send_message">Send</button>
          </p>
        </fieldset>
      </form>
    </section>

  </main>

  <!-- FOOTER -->
  <footer id="site_footer">
    <h3>Newsletter</h3>

    <!-- Newsletter form (email validation in JS) -->
    <form id="newsletter_form" action="#" method="post">
      <fieldset>
        <legend>Subscribe</legend>

        <p>
          <label for="newsletter_email">Email:</label><br />
          <input type="text" id="newsletter_email" name="newsletter_email" />
          <span class="error_text" id="err_newsletter_email"></span>
        </p>

        <p>
          <button type="button" id="btn_newsletter_subscribe">Subscribe</button>
        </p>
      </fieldset>
    </form>

    <p id="footer_text">
      &copy; 2026 Game Store
    </p>
  </footer>
</body>
</html>